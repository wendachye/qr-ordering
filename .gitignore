**/package-lock.json
**/yarn.lock

# ---- Build output ----
**/.next/
**/dist/
**/build/
**/out/
*.tsbuildinfo

# ---- Tests / coverage ----
**/coverage/

# ---- Environment files (the .env.example templates ARE committed) ----
.env
.env.*
!.env.example

# ---- Backend runtime uploads (user data; served from object storage in prod) ----
qr-ordering-backend/uploads/

# ---- Logs ----
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# ---- Editor / OS ----
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# ---- Local agent / tooling state (contains machine-specific paths) ----
.claude/
