# Backend API
# NOTE: in production (NODE_ENV=production) the server REFUSES TO START unless
# the secrets below are strong and CORS is locked down (see src/config/env.ts).
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/qr_ordering?schema=public"
PORT=4000
NODE_ENV=development

# Auth
# PRODUCTION: JWT_SECRET must be >= 32 random chars and not a default value.
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET="change-me"
JWT_EXPIRES_IN="7d"

# Print agent shared secret (must match print-agent/.env PRINT_AGENT_API_KEY).
# PRODUCTION: must be >= 16 random chars and not a default value.
PRINT_AGENT_API_KEY="secret-key"

# CORS: comma-separated list of allowed origins, or * for all (dev only).
# PRODUCTION: must NOT be "*" — list the admin + customer app origins, e.g.
#   CORS_ORIGIN="https://admin.yourdomain.com,https://order.yourdomain.com"
CORS_ORIGIN="*"

# Order numbering starts at BASE + 1 (first order = 1001)
ORDER_NUMBER_BASE=1000

# --- Reliability / ops ---
# Give up + alert after this many failed print attempts per ticket.
PRINT_MAX_RETRIES=5
# Optional: POST operational alerts (e.g. print failures) to this webhook URL.
ALERT_WEBHOOK_URL=

# --- Database connection pool (Prisma 7 pg driver adapter) ---
# Max pooled connections PER INSTANCE (pg default 10). Total DB connections ≈
# DB_POOL_MAX × number of app instances — size for your DB/pooler limits.
DB_POOL_MAX=10
# Fail a query that can't acquire a pooled connection after this long (ms).
DB_CONNECTION_TIMEOUT_MS=10000
# Cancel any single SQL statement running longer than this (ms).
DB_STATEMENT_TIMEOUT_MS=20000

# --- Upload storage ---
# 'local' (disk under /uploads, dev default) or 's3' (S3-compatible storage).
STORAGE_DRIVER=local
# Required when STORAGE_DRIVER=s3:
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Optional: S3_ENDPOINT for R2/MinIO; S3_PUBLIC_URL for a CDN base.
S3_ENDPOINT=
S3_PUBLIC_URL=

# --- Observability ---
# Log level: fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info
# Optional: Sentry DSN for error tracking (unset = disabled).
SENTRY_DSN=
# Optional: require this bearer token to scrape /metrics (recommended in prod).
METRICS_TOKEN=

# --- Billing (Stripe) ---
# Unset = billing disabled (trial-only / dev). Set all four for production checkout.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
# Free-trial length for new tenants (days).
BILLING_TRIAL_DAYS=14
# Admin app base URL for Stripe checkout/portal redirects.
APP_URL=http://localhost:3001
