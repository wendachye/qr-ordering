API_BASE_URL=http://localhost:4000
PRINT_AGENT_API_KEY=secret-key
PRINTER_IP=192.168.1.50
PRINTER_PORT=9100
POLL_INTERVAL_MS=2000

# Set to true to print tickets to the console instead of a physical printer.
PRINTER_DRY_RUN=false

# Characters per line: 48 for 80mm printers (ZY301), 32 for 58mm.
PRINTER_CHARS_PER_LINE=48
